{
  "id": "com.mercadoxpress.app",
  "name": "MercadoXpress",
  "short_name": "MercadoXpress",
  "description": "Tu catálogo digital y marketplace local.",
  "lang": "es-ES",
  "dir": "ltr",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#F8FAFC",
  "theme_color": "#6366F1",
  "categories": ["shopping", "business"],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "icons": [
    {
      "src": "./web-app-manifest-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "./web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "./web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "MercadoXpress en Escritorio"
    },
    {
      "src": "./web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "MercadoXpress en Móvil"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+mercadoxpress",
      "url": "./?open=%s"
    }
  ],
  "shortcuts": [
    {
      "name": "Ver Directorio",
      "short_name": "Directorio",
      "description": "Explora todos los negocios",
      "url": "./directory",
      "icons": [{ "src": "./web-app-manifest-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Mi Oficina",
      "short_name": "Oficina",
      "description": "Gestiona tus productos",
      "url": "./dashboard",
      "icons": [{ "src": "./web-app-manifest-192x192.png", "sizes": "192x192" }]
    }
  ]
}
